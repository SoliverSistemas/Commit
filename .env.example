# Configurações do Sistema
SECRET_KEY=change-me-in-production
# Configurações Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Chave secreta da aplicação
SECRET_KEY=your_secret_key_here

# Configurações de Cache e Rate Limit
GEOCODE_CACHE_TTL_SECONDS=86400
GEOCODE_RATE_LIMIT_PER_MIN=25

# Geoapify API Configuration
# Chave da API do Geoapify (obrigatória para cálculo de frete preciso)
# Para obter: https://www.geoapify.com/get-api-key
GEOAPIFY_API_KEY=your_geoapify_api_key_here
GEOAPIFY_CACHE_TTL_SECONDS=3600

# Configurações de E-mail (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# NOTA: Não configure ADMIN_EMAIL e ADMIN_PASSWORD_HASH aqui.
# Use o script registrar_admin_simples.py para criar usuários admin.
